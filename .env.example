# Lark (Feishu) Webhook Configuration
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token_here

# Monitoring Configuration
OI_THRESHOLD=5.0
PRICE_THRESHOLD=2.0
CHECK_INTERVAL=60
MIN_CHECK_INTERVAL=10
ADX_THRESHOLD=20.0

# Proxy Configuration (Optional)
# SOCKS5_PROXY=socks5://127.0.0.1:1080

# Signal Weight Configuration (Optional, default to 1.0)
BULLISH_BREAKOUT_WEIGHT=1.0
BEARISH_MOMENTUM_WEIGHT=1.0
POSSIBLE_FAKEOUT_WEIGHT=1.0
MARKET_CONTRACTION_WEIGHT=1.0

# HYPE Strategy Configuration (sensitive defaults)
HYPE_ONLY_MODE=true
HYPE_SYMBOL=HYPEUSDT
HYPE_OI_STOP_THRESHOLD=-0.05
HYPE_FR_EXTREME_THRESHOLD=-0.0001
HYPE_FR_RECOVERY_THRESHOLD=0.15
HYPE_HIGHER_LOW_PCT=0.5
HYPE_SQUEEZE_PRICE_PCT=0.3
HYPE_SQUEEZE_OI_DECLINE_PCT=0.02
HYPE_COOLDOWN_MINUTES=10
HYPE_LOOKBACK_KLINES=12
HYPE_FUNDING_INTERVAL=30

# Hyperliquid Data Source Configuration
HYPERLIQUID_ENABLED=false
HYPERLIQUID_OI_INTERVAL=10
HYPERLIQUID_FUNDING_INTERVAL=60
HYPE_HL_OI_STOP_THRESHOLD=-0.05
HYPE_HL_FR_EXTREME_THRESHOLD=-0.00002
HYPE_HL_FR_RECOVERY_THRESHOLD=0.15
HYPE_HL_SQUEEZE_PRICE_PCT=0.3
HYPE_HL_SQUEEZE_OI_DECLINE_PCT=0.02