# Lark (Feishu) Webhook Configuration
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token_here

# Monitoring Configuration
OI_THRESHOLD=5.0
PRICE_THRESHOLD=2.0
CHECK_INTERVAL=60
MIN_CHECK_INTERVAL=10
ADX_THRESHOLD=20.0

# Proxy Configuration (Optional)
# SOCKS5_PROXY=socks5://127.0.0.1:1080

# Signal Weight Configuration (Optional, default to 1.0)
BULLISH_BREAKOUT_WEIGHT=1.0
BEARISH_MOMENTUM_WEIGHT=1.0
POSSIBLE_FAKEOUT_WEIGHT=1.0
MARKET_CONTRACTION_WEIGHT=1.0
