# Docker 环境变量配置文件示例
# 使用方法: 
# 1. 复制此文件为 .env.docker
# 2. 填写实际的配置信息
# 3. 运行 docker-compose --env-file .env.docker up -d

# ============================================
# 必填配置
# ============================================

# 飞书机器人 Webhook URL
# 获取方式: 飞书群组 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
# 格式: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token_here

# ============================================
# 可选配置（使用默认值即可）
# ============================================

# OI 变化率阈值（百分比）
# 说明: 当持仓量变化超过此阈值时，可能触发信号
# 默认: 5.0
OI_THRESHOLD=5.0

# 价格变化率阈值（百分比）
# 说明: 当价格变化超过此阈值时，可能触发信号
# 默认: 2.0
PRICE_THRESHOLD=2.0

# OI 数据检查间隔（秒）
# 说明: 每隔多少秒检查一次 OI 数据
# 默认: 60
# 建议: 不要设置太小，避免触发 API 限制
CHECK_INTERVAL=60

# ============================================
# HYPE 专属策略配置（可选，使用默认值即可）
# ============================================

# HYPE 交易对
# 默认: HYPEUSDT
HYPE_SYMBOL=HYPEUSDT

# OI 止跌阈值（百分比）
# 说明: OI 变化率大于此值时，认为OI止跌
# 默认: -0.15
HYPE_OI_STOP_THRESHOLD=-0.15

# 资金费率极端阈值
# 说明: 费率低于此值时，认为空头极度拥挤
# 默认: -0.0005
HYPE_FR_EXTREME_THRESHOLD=-0.0005

# 资金费率回升比例
# 说明: 费率从极值回升超过此比例时，触发底部确认
# 默认: 0.3 (30%)
HYPE_FR_RECOVERY_THRESHOLD=0.3

# Higher Low 确认比例（百分比）
# 说明: 价格回踩不低于前低的此比例时，确认Higher Low
# 默认: 0.3
HYPE_HIGHER_LOW_PCT=0.3

# 轧空价格阈值（百分比）
# 说明: 15分钟涨幅超过此值时，可能触发轧空信号
# 默认: 0.5
HYPE_SQUEEZE_PRICE_PCT=0.5

# 轧空OI下降阈值（百分比）
# 说明: OI下降超过此值时，确认是空头平仓驱动
# 默认: 0.05
HYPE_SQUEEZE_OI_DECLINE_PCT=0.05

# 同类型信号冷却时间（分钟）
# 说明: 同类型信号至少间隔此时间才再次发送
# 默认: 15
HYPE_COOLDOWN_MINUTES=15

# 回溯K线数
# 说明: 用于计算ADX等指标的K线数量
# 默认: 12
HYPE_LOOKBACK_KLINES=12

# 资金费率轮询间隔（秒）
# 说明: 每隔多少秒获取一次资金费率
# 默认: 30
HYPE_FUNDING_INTERVAL=30
